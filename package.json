{
  "name": "sk-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import": "python3 src/scripts/import_labor_till.py",
    "sigma": "python3 src/scripts/sigma-fetch.py",
    "sigma:inject": "npx tsx src/scripts/sigma-inject.ts",
    "inject": "npx tsx src/scripts/mcp-inject-all.ts",
    "refresh": "npx tsx src/scripts/refresh.ts",
    "refresh-all": "npm run sigma && npm run refresh",
    "go": "concurrently -n proxy,dashboard -c cyan,teal \"python3 /Users/sam/azure-sql-proxy.py\" \"npm run dev\"",
    "deploy": "git add data && (git commit -m 'Refresh data' || true) && git push",
    "ship": "npm run refresh && npm run deploy",
    "refresh:full": "npm run inject && npm run ship"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "mssql": "^12.6.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
